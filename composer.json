{
    "name": "elysdan/emcaptcha",
    "description": "Arithmetic CAPTCHA for Laravel — generates math operation images (addition, subtraction, multiplication) with built-in validation.",
    "keywords": ["laravel", "captcha", "math", "arithmetic", "security"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Elysdan",
            "email": "elysdan@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/session": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "ext-gd": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Elysdan\\EMCaptcha\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elysdan\\EMCaptcha\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elysdan\\EMCaptcha\\EMCaptchaServiceProvider"
            ],
            "aliases": {
                "EMCaptcha": "Elysdan\\EMCaptcha\\Facades\\EMCaptcha"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
